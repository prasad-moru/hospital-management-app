<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Appointment Management</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><div class="d-flex justify-content-between"><h1>Appointment Management</h1><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST'||sessionScope.authenticatedUser.roleName=='PATIENT'}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/appointments/create">Book Appointment</a></c:if></div><c:if test="${not empty message}"><div class="alert alert-success">Appointment operation completed.</div></c:if><c:if test="${not empty error}"><div class="alert alert-danger">Appointment operation could not be completed.</div></c:if><form class="row g-2 my-3" method="get"><div class="col-md-3"><input class="form-control" name="search" value="<c:out value='${param.search}'/>" placeholder="Search appointments"></div><div class="col-md-2"><input class="form-control" type="date" name="dateFrom" value="<c:out value='${param.dateFrom}'/>"></div><div class="col-md-2"><input class="form-control" type="date" name="dateTo" value="<c:out value='${param.dateTo}'/>"></div><div class="col-md-2"><select class="form-select" name="status"><option value="">All statuses</option><c:forEach items="${['SCHEDULED','CONFIRMED','COMPLETED','CANCELLED','NO_SHOW']}" var="s"><option value="${s}" ${param.status==s?'selected':''}><c:out value="${s}"/></option></c:forEach></select></div><div class="col"><button class="btn btn-outline-primary">Filter</button></div></form><div class="table-responsive"><table class="table table-striped align-middle"><thead><tr><th>ID</th><th>Date</th><th>Time</th><th>Patient</th><th>Doctor</th><th>Department</th><th>Reason</th><th>Status</th><th>Actions</th></tr></thead><tbody><c:forEach items="${appointmentPage.content}" var="a"><tr><td><c:out value="${a.appointmentId}"/></td><td><c:out value="${a.appointmentDate}"/></td><td><c:out value="${a.startTime}"/>–<c:out value="${a.endTime}"/></td><td><c:out value="${a.patientName}"/></td><td><c:out value="${a.doctorName}"/></td><td><c:out value="${a.departmentName}"/></td><td><c:out value="${a.reason}"/></td><td><span class="badge text-bg-secondary"><c:out value="${a.status}"/></span></td><td><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/appointments/view?id=${a.appointmentId}">View</a></td></tr></c:forEach><c:if test="${empty appointmentPage.content}"><tr><td colspan="9" class="text-center py-4">No appointments found.</td></tr></c:if></tbody></table></div><nav><c:if test="${!appointmentPage.first}"><a class="btn btn-outline-secondary" href="?page=${appointmentPage.pageNumber-1}&amp;size=${appointmentPage.pageSize}">Previous</a></c:if><span class="mx-2">Page <c:out value="${appointmentPage.pageNumber}"/> of <c:out value="${appointmentPage.totalPages}"/></span><c:if test="${!appointmentPage.last}"><a class="btn btn-outline-secondary" href="?page=${appointmentPage.pageNumber+1}&amp;size=${appointmentPage.pageSize}">Next</a></c:if></nav></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
