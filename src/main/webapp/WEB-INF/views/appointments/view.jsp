<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Appointment</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Appointment #<c:out value="${appointment.appointmentId}"/></h1><dl class="row"><dt class="col-sm-3">Patient</dt><dd class="col-sm-9"><c:out value="${appointment.patientName}"/> (<c:out value="${appointment.patientNumber}"/>)</dd><dt class="col-sm-3">Doctor / Department</dt><dd class="col-sm-9"><c:out value="${appointment.doctorName}"/> / <c:out value="${appointment.departmentName}"/></dd><dt class="col-sm-3">Date and time</dt><dd class="col-sm-9"><c:out value="${appointment.appointmentDate}"/> <c:out value="${appointment.startTime}"/>–<c:out value="${appointment.endTime}"/></dd><dt class="col-sm-3">Reason</dt><dd class="col-sm-9"><c:out value="${appointment.reason}"/></dd><dt class="col-sm-3">Notes</dt><dd class="col-sm-9"><c:out value="${appointment.notes}"/></dd><dt class="col-sm-3">Status</dt><dd class="col-sm-9"><c:out value="${appointment.status}"/></dd></dl><a class="btn btn-secondary" href="${pageContext.request.contextPath}/appointments">Back</a>
<c:if test="${not empty medicalRecord}"><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='DOCTOR'||sessionScope.authenticatedUser.roleName=='PATIENT'}"><a class="btn btn-info" href="${pageContext.request.contextPath}/medical-records/view?id=${medicalRecord.medicalRecordId}">View Medical Record</a></c:if></c:if><c:if test="${empty medicalRecord&&(appointment.status=='CONFIRMED'||appointment.status=='COMPLETED')&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='DOCTOR')}"><a class="btn btn-info" href="${pageContext.request.contextPath}/medical-records/create?appointmentId=${appointment.appointmentId}">Add Medical Record</a></c:if>
<c:if test="${not empty bill&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='BILLING_STAFF'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST'||sessionScope.authenticatedUser.roleName=='PATIENT')}"><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/billing/view?id=${bill.billId}">View Bill</a></c:if><c:if test="${empty bill&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='BILLING_STAFF'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST')}"><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/billing/create?appointmentId=${appointment.appointmentId}">Create Bill</a></c:if>
<c:if test="${appointment.status=='SCHEDULED'||appointment.status=='CONFIRMED'}"><c:if test="${sessionScope.authenticatedUser.roleName!='PATIENT'}"><a class="btn btn-outline-primary" href="${pageContext.request.contextPath}/appointments/edit?id=${appointment.appointmentId}">Edit details</a></c:if><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST'||sessionScope.authenticatedUser.roleName=='PATIENT'}"><a class="btn btn-outline-primary" href="${pageContext.request.contextPath}/appointments/reschedule?id=${appointment.appointmentId}">Reschedule</a></c:if><form class="d-inline" method="post" action="${pageContext.request.contextPath}/appointments/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="appointmentId" value="${appointment.appointmentId}"><c:if test="${appointment.status=='SCHEDULED'&&sessionScope.authenticatedUser.roleName!='PATIENT'}"><button class="btn btn-success" name="action" value="confirm">Confirm</button></c:if><c:if test="${appointment.status=='CONFIRMED'&&(sessionScope.authenticatedUser.roleName=='DOCTOR'||sessionScope.authenticatedUser.roleName=='ADMIN')}"><button class="btn btn-success" name="action" value="complete">Complete</button><button class="btn btn-warning" name="action" value="no_show">No-show</button></c:if><button class="btn btn-danger" name="action" value="cancel">Cancel</button></form></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
