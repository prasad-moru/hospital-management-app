<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Reschedule Appointment</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Reschedule Appointment</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post" class="card card-body"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="appointmentId" value="${appointmentForm.appointmentId}"><input type="hidden" id="doctorId" name="doctorId" value="${appointmentForm.doctorId}"><input type="hidden" name="patientId" value="${appointmentForm.patientId}"><label class="form-label">Date</label><input class="form-control" id="appointmentDate" type="date" name="appointmentDate" value="<c:out value='${appointmentForm.appointmentDate}'/>" required><label class="form-label mt-3">Available time</label><select class="form-select" id="startTime" name="startTime" required></select><label class="form-label mt-3">Reason</label><textarea class="form-control" name="reason" maxlength="500" required><c:out value="${appointmentForm.reason}"/></textarea><label class="form-label mt-3">Notes</label><textarea class="form-control" name="notes" maxlength="1000"><c:out value="${appointmentForm.notes}"/></textarea><button class="btn btn-primary mt-3">Reschedule</button></form></main><script>const d=document.getElementById('doctorId'),dt=document.getElementById('appointmentDate'),s=document.getElementById('startTime');async function load(){const r=await fetch('${pageContext.request.contextPath}/appointments/slots?doctorId='+d.value+'&appointmentDate='+dt.value+'&excludeAppointmentId=${appointmentForm.appointmentId}');const x=await r.json();s.innerHTML='';x.forEach(v=>{const o=document.createElement('option');o.value=v.startTime;o.textContent=v.startTime+' - '+v.endTime;s.appendChild(o)});}dt.addEventListener('change',load);load();</script><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
