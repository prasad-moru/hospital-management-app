<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Edit Admission</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Edit <c:out value="${admission.admissionNumber}"/></h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="admissionId" value="${admissionForm.admissionId}"><input type="hidden" name="patientId" value="${admissionForm.patientId}"><input type="hidden" name="appointmentId" value="${admissionForm.appointmentId}"><input type="hidden" name="bedId" value="${admissionForm.bedId}"><label class="form-label">Doctor ID</label><input class="form-control" type="number" min="1" name="doctorId" value="${admissionForm.doctorId}" required><label class="form-label mt-2">Department ID</label><input class="form-control" type="number" min="1" name="departmentId" value="${admissionForm.departmentId}" required><label class="form-label mt-2">Expected discharge</label><input class="form-control" type="date" name="expectedDischargeDate" value="${admissionForm.expectedDischargeDate}"><label class="form-label mt-2">Admission reason</label><textarea class="form-control" name="admissionReason" maxlength="1000" required><c:out value="${admissionForm.admissionReason}"/></textarea><button class="btn btn-primary mt-3">Save</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
