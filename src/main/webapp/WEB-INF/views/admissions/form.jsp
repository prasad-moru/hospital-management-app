<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Admit Patient</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Admit Patient</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post" id="admissionForm" data-context-path="${pageContext.request.contextPath}"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><div class="row g-2"><div class="col"><input class="form-control" name="patientId" type="number" min="1" placeholder="Patient ID" value="<c:out value='${admissionForm.patientId}'/>" required></div><div class="col"><input class="form-control" name="doctorId" type="number" min="1" placeholder="Doctor ID" value="<c:out value='${admissionForm.doctorId}'/>" required></div><div class="col"><input id="departmentId" class="form-control" name="departmentId" type="number" min="1" placeholder="Department ID" value="<c:out value='${admissionForm.departmentId}'/>" required></div><div class="col"><input class="form-control" name="appointmentId" type="number" min="1" placeholder="Appointment ID optional" value="<c:out value='${admissionForm.appointmentId}'/>"></div></div><label class="form-label mt-3">Room type</label><select id="roomType" class="form-select"><option value="">Any active room</option><option>GENERAL</option><option>SEMI_PRIVATE</option><option>PRIVATE</option><option>ICU</option><option>EMERGENCY</option><option>MATERNITY</option><option>PEDIATRIC</option><option>OTHER</option></select><label class="form-label mt-3">Available bed</label><select id="bedId" class="form-select" name="bedId" data-selected="<c:out value='${admissionForm.bedId}'/>" required><option>Loading available beds...</option></select><label class="form-label mt-3">Expected discharge</label><input class="form-control" type="date" name="expectedDischargeDate" value="<c:out value='${admissionForm.expectedDischargeDate}'/>"><label class="form-label mt-3">Admission reason</label><textarea class="form-control" name="admissionReason" maxlength="1000" required><c:out value="${admissionForm.admissionReason}"/></textarea><button class="btn btn-primary mt-3">Admit Patient</button></form></main><script src="${pageContext.request.contextPath}/assets/js/admissions.js" defer></script><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
