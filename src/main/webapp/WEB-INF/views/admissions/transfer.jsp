<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Transfer Patient</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Transfer <c:out value="${admission.admissionNumber}"/></h1><p>Current: Room <c:out value="${admission.roomNumber}"/> / Bed <c:out value="${admission.bedNumber}"/></p><form method="post" id="admissionForm" data-context-path="${pageContext.request.contextPath}"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="admissionId" value="${admission.admissionId}"><select id="bedId" class="form-select" name="targetBedId" required></select><textarea class="form-control mt-3" name="transferReason" maxlength="500" placeholder="Transfer reason" required></textarea><button class="btn btn-primary mt-3">Transfer</button></form></main><script src="${pageContext.request.contextPath}/assets/js/admissions.js" defer></script><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
