<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Admissions</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><div class="d-flex justify-content-between"><h1>Admissions</h1><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST'}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/admissions/create">Admit Patient</a></c:if></div><form class="row g-2 my-3"><div class="col"><input class="form-control" name="search" value="<c:out value='${param.search}'/>" placeholder="Admission, patient, room or bed"></div><div class="col"><select class="form-select" name="status"><option value="">All statuses</option><option>ADMITTED</option><option>DISCHARGED</option><option>CANCELLED</option></select></div><div class="col-auto"><button class="btn btn-outline-primary">Filter</button></div></form><table class="table table-striped"><thead><tr><th>Admission</th><th>Date</th><th>Patient</th><th>Doctor</th><th>Department</th><th>Room</th><th>Bed</th><th>Expected discharge</th><th>Status</th><th></th></tr></thead><tbody><c:forEach items="${admissionPage.content}" var="a"><tr><td><c:out value="${a.admissionNumber}"/></td><td><c:out value="${a.admissionDate}"/></td><td><c:out value="${a.patientName}"/></td><td><c:out value="${a.doctorName}"/></td><td><c:out value="${a.departmentName}"/></td><td><c:out value="${a.roomNumber}"/></td><td><c:out value="${a.bedNumber}"/></td><td><c:out value="${a.expectedDischargeDate}"/></td><td><c:out value="${a.status}"/></td><td><a href="${pageContext.request.contextPath}/admissions/view?id=${a.admissionId}">View</a></td></tr></c:forEach><c:if test="${empty admissionPage.content}"><tr><td colspan="10" class="text-center">No admissions found.</td></tr></c:if></tbody></table></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
