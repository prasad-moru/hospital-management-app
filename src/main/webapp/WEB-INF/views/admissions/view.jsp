<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Admission</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Admission <c:out value="${admission.admissionNumber}"/></h1><dl class="row"><dt class="col-3">Status</dt><dd class="col-9"><c:out value="${admission.status}"/></dd><dt class="col-3">Patient</dt><dd class="col-9"><c:out value="${admission.patientName}"/> (<c:out value="${admission.patientNumber}"/>)</dd><dt class="col-3">Doctor / Department</dt><dd class="col-9"><c:out value="${admission.doctorName}"/> / <c:out value="${admission.departmentName}"/></dd><dt class="col-3">Room / Bed</dt><dd class="col-9"><c:out value="${admission.roomNumber}"/> / <c:out value="${admission.bedNumber}"/> — <c:out value="${admission.roomType}"/> ₹<c:out value="${admission.dailyRate}"/> per day</dd><dt class="col-3">Dates</dt><dd class="col-9"><c:out value="${admission.admissionDate}"/> to <c:out value="${admission.actualDischargeDate}"/></dd><dt class="col-3">Reason</dt><dd class="col-9"><c:out value="${admission.admissionReason}"/></dd><dt class="col-3">Discharge summary</dt><dd class="col-9"><c:out value="${admission.dischargeSummary}"/></dd></dl><a class="btn btn-secondary" href="${pageContext.request.contextPath}/admissions">Back</a><c:if test="${(admission.status=='ADMITTED'||admission.status=='TRANSFERRED')&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST')}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/admissions/transfer?id=${admission.admissionId}">Transfer</a> <a class="btn btn-success" href="${pageContext.request.contextPath}/admissions/discharge?id=${admission.admissionId}">Discharge</a><form class="d-inline" method="post" action="${pageContext.request.contextPath}/admissions/status"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="admissionId" value="${admission.admissionId}"><button class="btn btn-danger" name="action" value="cancel">Cancel</button></form></c:if><c:if test="${not empty admission.billId}"> <a class="btn btn-outline-success" href="${pageContext.request.contextPath}/billing/view?id=${admission.billId}">View Bill</a></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
