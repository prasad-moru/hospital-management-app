<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Prescription</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>${formMode=='CREATE'?'Create':'Edit'} Prescription</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post" id="prescriptionForm"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="prescriptionId" value="<c:out value='${prescriptionForm.prescriptionId}'/>"><input type="hidden" name="medicalRecordId" value="<c:out value='${prescriptionForm.medicalRecordId}'/>"><label class="form-label">Valid until</label><input class="form-control" type="date" name="validUntil" value="<c:out value='${prescriptionForm.validUntil}'/>"><label class="form-label mt-2">Notes</label><textarea class="form-control" name="notes" maxlength="2000"><c:out value="${prescriptionForm.notes}"/></textarea><input type="hidden" name="status" value="ACTIVE"><h2 class="h5 mt-4">Medicines</h2><div id="prescriptionItems" data-max="20"><c:forEach items="${prescriptionForm.items}" var="i" varStatus="v"><div class="card card-body mb-2 prescription-item"><div class="row g-2"><div class="col-md-3"><input class="form-control medicine-name" name="items[${v.index}].medicineName" value="<c:out value='${i.medicineName}'/>" placeholder="Medicine" required></div><div class="col"><input class="form-control dosage" name="items[${v.index}].dosage" value="<c:out value='${i.dosage}'/>" placeholder="Dosage" required></div><div class="col"><input class="form-control frequency" name="items[${v.index}].frequency" value="<c:out value='${i.frequency}'/>" placeholder="Frequency" required></div><div class="col"><input class="form-control duration" name="items[${v.index}].duration" value="<c:out value='${i.duration}'/>" placeholder="Duration" required></div><div class="col"><input class="form-control route" name="items[${v.index}].route" value="<c:out value='${i.route}'/>" placeholder="Route"></div><div class="col-md-3"><input class="form-control instructions" name="items[${v.index}].instructions" value="<c:out value='${i.instructions}'/>" placeholder="Instructions"></div><div class="col-auto"><button type="button" class="btn btn-outline-danger remove-item">Remove</button></div></div></div></c:forEach></div><button type="button" id="addPrescriptionItem" class="btn btn-outline-primary">Add Item</button> <button class="btn btn-primary">Save Prescription</button></form></main><script src="${pageContext.request.contextPath}/assets/js/prescriptions.js" defer></script><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
