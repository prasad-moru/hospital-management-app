<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Prescriptions</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><h1>Prescriptions</h1><form class="row g-2 my-3"><div class="col-md-4"><input class="form-control" name="search" value="<c:out value='${param.search}'/>" placeholder="Search prescriptions"></div><div class="col-md-2"><input class="form-control" type="date" name="dateFrom" value="<c:out value='${param.dateFrom}'/>"></div><div class="col-md-2"><input class="form-control" type="date" name="dateTo" value="<c:out value='${param.dateTo}'/>"></div><div class="col-md-2"><select class="form-select" name="status"><option value="">All statuses</option><option>ACTIVE</option><option>COMPLETED</option><option>CANCELLED</option></select></div><button class="btn btn-outline-primary col">Filter</button></form><div class="table-responsive"><table class="table table-striped"><thead><tr><th>ID</th><th>Date</th><th>Patient</th><th>Doctor</th><th>Department</th><th>Medical Record</th><th>Valid Until</th><th>Status</th><th>Actions</th></tr></thead><tbody><c:forEach items="${prescriptionPage.content}" var="p"><tr><td><c:out value="${p.prescriptionId}"/></td><td><c:out value="${p.prescriptionDate}"/></td><td><c:out value="${p.patientName}"/></td><td><c:out value="${p.doctorName}"/></td><td><c:out value="${p.departmentName}"/></td><td>#<c:out value="${p.medicalRecordId}"/></td><td><c:out value="${p.validUntil}"/></td><td><span class="badge text-bg-secondary"><c:out value="${p.status}"/></span></td><td><a class="btn btn-sm btn-primary" href="${pageContext.request.contextPath}/prescriptions/view?id=${p.prescriptionId}">View</a> <a class="btn btn-sm btn-outline-secondary" href="${pageContext.request.contextPath}/prescriptions/print?id=${p.prescriptionId}">Print</a></td></tr></c:forEach><c:if test="${empty prescriptionPage.content}"><tr><td colspan="9" class="text-center">No prescriptions found.</td></tr></c:if></tbody></table></div><c:choose><c:when test="${prescriptionPage.totalPages==0}"><span>No pages</span></c:when><c:otherwise><span>Page <c:out value="${prescriptionPage.pageNumber}"/> of <c:out value="${prescriptionPage.totalPages}"/></span></c:otherwise></c:choose></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
