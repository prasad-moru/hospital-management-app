<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Prescription</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Prescription #<c:out value="${prescription.prescriptionId}"/></h1><p><strong>Patient:</strong> <c:out value="${prescription.patientName}"/> (<c:out value="${prescription.patientNumber}"/>)</p><p><strong>Doctor:</strong> <c:out value="${prescription.doctorName}"/> — <c:out value="${prescription.departmentName}"/></p><p><strong>Date:</strong> <c:out value="${prescription.prescriptionDate}"/> | <strong>Valid until:</strong> <c:out value="${prescription.validUntil}"/> | <strong>Status:</strong> <c:out value="${prescription.status}"/></p><table class="table table-bordered"><thead><tr><th>Medicine</th><th>Dosage</th><th>Frequency</th><th>Duration</th><th>Route</th><th>Instructions</th></tr></thead><tbody><c:forEach items="${prescription.items}" var="i"><tr><td><c:out value="${i.medicineName}"/></td><td><c:out value="${i.dosage}"/></td><td><c:out value="${i.frequency}"/></td><td><c:out value="${i.duration}"/></td><td><c:out value="${i.route}"/></td><td><c:out value="${i.instructions}"/></td></tr></c:forEach></tbody></table><p><strong>Notes:</strong> <c:out value="${prescription.notes}"/></p><a class="btn btn-secondary" href="${pageContext.request.contextPath}/prescriptions">Back</a><a class="btn btn-outline-primary" href="${pageContext.request.contextPath}/prescriptions/print?id=${prescription.prescriptionId}">Print</a><c:if test="${prescription.status=='ACTIVE'&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='DOCTOR')}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/prescriptions/edit?id=${prescription.prescriptionId}">Edit</a><form class="d-inline" method="post" action="${pageContext.request.contextPath}/prescriptions/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="prescriptionId" value="${prescription.prescriptionId}"><button class="btn btn-success" name="action" value="complete">Complete</button><button class="btn btn-danger" name="action" value="cancel">Cancel</button></form></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
