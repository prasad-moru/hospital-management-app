<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Schedule Details</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="card"><div class="card-body"><h1>Schedule Details</h1><dl class="row"><c:forEach items="${['scheduleId','doctorName','departmentName','dayOfWeek','startTime','endTime','slotDurationMinutes','available','createdAt','updatedAt']}" var="f"><dt class="col-sm-4"><c:out value="${f}"/></dt><dd class="col-sm-8"><c:out value="${schedule[f]}"/></dd></c:forEach></dl><a class="btn btn-primary" href="${pageContext.request.contextPath}/schedules/edit?id=${schedule.scheduleId}">Edit</a> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/schedules">Back</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/schedules/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="scheduleId" value="${schedule.scheduleId}"><input type="hidden" name="action" value="${schedule.available?'deactivate':'activate'}"><button class="btn btn-outline-warning">${schedule.available?'Deactivate':'Activate'}</button></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
