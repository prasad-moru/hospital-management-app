<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>${formMode=='CREATE'?'Add':'Edit'} Schedule</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="card shadow-sm"><div class="card-body"><h1>${formMode=='CREATE'?'Add':'Edit'} Schedule</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><c:if test="${formMode=='EDIT'}"><input type="hidden" name="scheduleId" value="${scheduleForm.scheduleId}"></c:if><div class="row g-3"><div class="col-md-6"><label>Doctor</label><c:choose><c:when test="${sessionScope.authenticatedUser.roleName=='ADMIN'}"><select class="form-select" name="doctorId" required><option value="">Select doctor</option><c:forEach items="${doctors}" var="d"><option value="${d.doctorId}" ${scheduleForm.doctorId==d.doctorId?'selected':''}><c:out value="${d.fullName}"/> - <c:out value="${d.departmentName}"/></option></c:forEach></select></c:when><c:otherwise><input type="hidden" name="doctorId" value="${ownDoctor.doctorId}"><input class="form-control" readonly value="<c:out value='${ownDoctor.fullName}'/>"></c:otherwise></c:choose><div class="text-danger"><c:out value="${errors.doctorId}"/></div></div><div class="col-md-6"><label>Day</label><select class="form-select" name="dayOfWeek"><c:forEach items="${['MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY','SUNDAY']}" var="d"><option ${scheduleForm.dayOfWeek==d?'selected':''}><c:out value="${d}"/></option></c:forEach></select></div><div class="col-md-4"><label>Start time</label><input type="time" class="form-control" name="startTime" required value="<c:out value='${scheduleForm.startTime}'/>"><div class="text-danger"><c:out value="${errors.startTime}"/></div></div><div class="col-md-4"><label>End time</label><input type="time" class="form-control" name="endTime" required value="<c:out value='${scheduleForm.endTime}'/>"><div class="text-danger"><c:out value="${errors.endTime}"/></div></div><div class="col-md-4"><label>Slot duration</label><input type="number" min="5" max="240" class="form-control" name="slotDurationMinutes" required value="<c:out value='${scheduleForm.slotDurationMinutes}'/>"><div class="text-danger"><c:out value="${errors.slotDurationMinutes}"/></div></div><div class="col-12 form-check ms-2"><input class="form-check-input" type="checkbox" name="available" value="true" ${scheduleForm.available?'checked':''}><label>Available</label></div></div><button class="btn btn-primary mt-4">Save Schedule</button> <a class="btn btn-outline-secondary mt-4" href="${pageContext.request.contextPath}/schedules">Cancel</a></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
