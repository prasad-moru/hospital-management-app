<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Doctor Schedule Management</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid px-lg-5 py-4"><div class="d-flex justify-content-between"><h1>Doctor Schedule Management</h1><a class="btn btn-primary" href="${pageContext.request.contextPath}/schedules/create">Add Schedule</a></div><c:if test="${not empty message}"><div class="alert alert-success">Schedule operation completed.</div></c:if><c:if test="${not empty error}"><div class="alert alert-warning">Schedule operation was blocked or unavailable.</div></c:if><form class="row g-2 my-3" method="get"><div class="col"><input class="form-control" name="search" value="<c:out value='${search}'/>" placeholder="Doctor, registration, department..."></div><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'}"><div class="col-md-2"><select class="form-select" name="doctorId"><option value="">All doctors</option><c:forEach items="${doctors}" var="d"><option value="${d.doctorId}" ${doctorId==d.doctorId?'selected':''}><c:out value="${d.fullName}"/></option></c:forEach></select></div><div class="col-md-2"><select class="form-select" name="departmentId"><option value="">All departments</option><c:forEach items="${doctors}" var="d"><option value="${d.departmentId}" ${departmentId==d.departmentId?'selected':''}><c:out value="${d.departmentName}"/></option></c:forEach></select></div></c:if><div class="col-md-2"><select class="form-select" name="dayOfWeek"><option value="">All days</option><c:forEach items="${['MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY','SUNDAY']}" var="day"><option ${dayOfWeek==day?'selected':''}><c:out value="${day}"/></option></c:forEach></select></div><div class="col-md-2"><select class="form-select" name="available"><option value="">All availability</option><option value="true" ${available==true?'selected':''}>AVAILABLE</option><option value="false" ${available==false?'selected':''}>INACTIVE</option></select></div><div class="col-auto"><button class="btn btn-outline-primary">Filter</button></div></form><div class="table-responsive"><table class="table table-hover"><thead><tr><th>ID</th><th>Doctor</th><th>Department</th><th>Day</th><th>Start</th><th>End</th><th>Slot Minutes</th><th>Availability</th><th>Actions</th></tr></thead><tbody><c:forEach items="${schedulePage.content}" var="s"><tr><td><c:out value="${s.scheduleId}"/></td><td><c:out value="${s.doctorName}"/></td><td><c:out value="${s.departmentName}"/></td><td><c:out value="${s.dayOfWeek}"/></td><td><c:out value="${s.startTime}"/></td><td><c:out value="${s.endTime}"/></td><td><c:out value="${s.slotDurationMinutes}"/></td><td><span class="badge ${s.available?'bg-success':'bg-secondary'}">${s.available?'AVAILABLE':'INACTIVE'}</span></td><td><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/schedules/view?id=${s.scheduleId}">View</a> <a class="btn btn-sm btn-outline-dark" href="${pageContext.request.contextPath}/schedules/edit?id=${s.scheduleId}">Edit</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/schedules/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="scheduleId" value="${s.scheduleId}"><input type="hidden" name="action" value="${s.available?'deactivate':'activate'}"><button class="btn btn-sm btn-outline-warning">${s.available?'Deactivate':'Activate'}</button></form></td></tr></c:forEach><c:if test="${empty schedulePage.content}"><tr><td colspan="9" class="text-center py-4">No schedules found.</td></tr></c:if></tbody></table></div><nav><ul class="pagination"><c:forEach begin="1" end="${schedulePage.totalPages}" var="p"><c:url var="url" value="/schedules"><c:param name="page" value="${p}"/><c:param name="search" value="${search}"/><c:param name="doctorId" value="${doctorId}"/><c:param name="departmentId" value="${departmentId}"/><c:param name="dayOfWeek" value="${dayOfWeek}"/><c:param name="available" value="${available}"/></c:url><li class="page-item ${p==schedulePage.pageNumber?'active':''}"><a class="page-link" href="${url}">${p}</a></li></c:forEach></ul></nav></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
