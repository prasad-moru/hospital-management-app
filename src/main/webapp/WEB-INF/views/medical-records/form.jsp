<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>${formMode=='CREATE'?'Create':'Edit'} Medical Record</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>${formMode=='CREATE'?'Create':'Edit'} Medical Record</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><div class="card card-body mb-3"><c:choose><c:when test="${formMode=='CREATE'}"><p>Appointment #<c:out value="${appointment.appointmentId}"/> — <c:out value="${appointment.appointmentDate}"/> <c:out value="${appointment.startTime}"/></p><p>Patient: <c:out value="${appointment.patientName}"/> | Doctor: <c:out value="${appointment.doctorName}"/> | Department: <c:out value="${appointment.departmentName}"/></p></c:when><c:otherwise><p>Appointment #<c:out value="${record.appointmentId}"/> — <c:out value="${record.appointmentDate}"/> <c:out value="${record.appointmentStartTime}"/></p><p>Patient: <c:out value="${record.patientName}"/> | Doctor: <c:out value="${record.doctorName}"/> | Department: <c:out value="${record.departmentName}"/></p></c:otherwise></c:choose></div><form method="post" class="card card-body"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="medicalRecordId" value="<c:out value='${recordForm.medicalRecordId}'/>"><input type="hidden" name="appointmentId" value="<c:out value='${recordForm.appointmentId}'/>"><label class="form-label">Symptoms</label><textarea class="form-control" name="symptoms" maxlength="2000" required><c:out value="${recordForm.symptoms}"/></textarea><div class="text-danger"><c:out value="${errors.symptoms}"/></div><label class="form-label mt-3">Diagnosis</label><textarea class="form-control" name="diagnosis" maxlength="2000" required><c:out value="${recordForm.diagnosis}"/></textarea><div class="text-danger"><c:out value="${errors.diagnosis}"/></div><label class="form-label mt-3">Treatment notes</label><textarea class="form-control" name="treatmentNotes" maxlength="4000"><c:out value="${recordForm.treatmentNotes}"/></textarea><label class="form-label mt-3">Allergies</label><textarea class="form-control" name="allergies" maxlength="1000"><c:out value="${recordForm.allergies}"/></textarea><div class="row g-3 mt-1"><div class="col-md"><label class="form-label">Blood pressure</label><input class="form-control" name="bloodPressure" placeholder="120/80" value="<c:out value='${recordForm.bloodPressure}'/>"></div><div class="col-md"><label class="form-label">Temperature °C</label><input class="form-control" type="number" step="0.1" name="temperature" value="<c:out value='${recordForm.temperature}'/>"></div><div class="col-md"><label class="form-label">Weight kg</label><input class="form-control" type="number" step="0.01" name="weight" value="<c:out value='${recordForm.weight}'/>"></div><div class="col-md"><label class="form-label">Height cm</label><input class="form-control" type="number" step="0.01" name="height" value="<c:out value='${recordForm.height}'/>"></div></div><button class="btn btn-primary mt-3">Save Medical Record</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
