<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Medical Record</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Medical Record #<c:out value="${record.medicalRecordId}"/></h1><div class="card"><div class="card-body"><dl class="row"><dt class="col-sm-3">Appointment</dt><dd class="col-sm-9"><a href="${pageContext.request.contextPath}/appointments/view?id=${record.appointmentId}">#<c:out value="${record.appointmentId}"/></a> — <c:out value="${record.appointmentDate}"/> <c:out value="${record.appointmentStartTime}"/></dd><dt class="col-sm-3">Visit date</dt><dd class="col-sm-9"><c:out value="${record.visitDate}"/></dd><dt class="col-sm-3">Patient</dt><dd class="col-sm-9"><c:out value="${record.patientName}"/> (<c:out value="${record.patientNumber}"/>)</dd><dt class="col-sm-3">Doctor / Department</dt><dd class="col-sm-9"><c:out value="${record.doctorName}"/> / <c:out value="${record.departmentName}"/></dd><dt class="col-sm-3">Symptoms</dt><dd class="col-sm-9"><c:out value="${record.symptoms}"/></dd><dt class="col-sm-3">Diagnosis</dt><dd class="col-sm-9"><c:out value="${record.diagnosis}"/></dd><dt class="col-sm-3">Treatment notes</dt><dd class="col-sm-9"><c:out value="${record.treatmentNotes}"/></dd><dt class="col-sm-3">Allergies</dt><dd class="col-sm-9"><c:out value="${record.allergies}"/></dd><dt class="col-sm-3">Vital signs</dt><dd class="col-sm-9">BP <c:out value="${record.bloodPressure}"/>; Temperature <c:out value="${record.temperature}"/> °C; Weight <c:out value="${record.weight}"/> kg; Height <c:out value="${record.height}"/> cm</dd><dt class="col-sm-3">Created / updated</dt><dd class="col-sm-9"><c:out value="${record.createdAt}"/> / <c:out value="${record.updatedAt}"/></dd></dl></div></div><div class="mt-3"><a class="btn btn-secondary" href="${pageContext.request.contextPath}/medical-records">Back</a><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='DOCTOR'}"> <a class="btn btn-primary" href="${pageContext.request.contextPath}/medical-records/edit?id=${record.medicalRecordId}">Edit</a></c:if></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
