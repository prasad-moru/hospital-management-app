<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Medical Records</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><h1>Medical Records</h1><form class="row g-2 my-3" method="get"><div class="col-md-5"><input class="form-control" name="search" value="<c:out value='${param.search}'/>" placeholder="Search patient, doctor, department or diagnosis"></div><div class="col-md-2"><input class="form-control" type="date" name="dateFrom" value="<c:out value='${param.dateFrom}'/>"></div><div class="col-md-2"><input class="form-control" type="date" name="dateTo" value="<c:out value='${param.dateTo}'/>"></div><div class="col"><button class="btn btn-outline-primary">Filter</button></div></form><div class="table-responsive"><table class="table table-striped"><thead><tr><th>ID</th><th>Visit Date</th><th>Patient</th><th>Doctor</th><th>Department</th><th>Appointment</th><th>Diagnosis Summary</th><th>Actions</th></tr></thead><tbody><c:forEach items="${recordPage.content}" var="m"><tr><td><c:out value="${m.medicalRecordId}"/></td><td><c:out value="${m.visitDate}"/></td><td><c:out value="${m.patientName}"/></td><td><c:out value="${m.doctorName}"/></td><td><c:out value="${m.departmentName}"/></td><td><c:out value="${m.appointmentDate}"/></td><td><c:out value="${m.diagnosis.length()>80?m.diagnosis.substring(0,80):m.diagnosis}"/></td><td><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/medical-records/view?id=${m.medicalRecordId}">View</a><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='DOCTOR'}"> <a class="btn btn-sm btn-outline-secondary" href="${pageContext.request.contextPath}/medical-records/edit?id=${m.medicalRecordId}">Edit</a></c:if></td></tr></c:forEach><c:if test="${empty recordPage.content}"><tr><td colspan="8" class="text-center py-4">No medical records found.</td></tr></c:if></tbody></table></div><c:if test="${!recordPage.first}"><a class="btn btn-outline-secondary" href="?page=${recordPage.pageNumber-1}&amp;size=${recordPage.pageSize}">Previous</a></c:if><span class="mx-2">Page <c:out value="${recordPage.pageNumber}"/> of <c:out value="${recordPage.totalPages}"/></span><c:if test="${!recordPage.last}"><a class="btn btn-outline-secondary" href="?page=${recordPage.pageNumber+1}&amp;size=${recordPage.pageSize}">Next</a></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
