<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>${formMode=='CREATE'?'Add':'Edit'} Patient</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="card shadow-sm"><div class="card-body"><h1>${formMode=='CREATE'?'Add':'Edit'} Patient</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><c:if test="${formMode=='EDIT'}"><input type="hidden" name="patientId" value="<c:out value='${patientForm.patientId}'/>"><input type="hidden" name="linkedAccount" value="${linkedAccount}"/></c:if><h2 class="h5 mt-3">Patient Identity</h2><div class="row g-3"><c:forEach items="${['patientNumber','firstName','lastName','dateOfBirth']}" var="f"><div class="col-md-6"><label class="form-label"><c:out value="${f}"/></label><input class="form-control" name="${f}" ${f=='dateOfBirth'?'type="date"':''} value="<c:out value='${patientForm[f]}'/>" ${f=='patientNumber'?'placeholder="Generated when blank"':'required'}><div class="text-danger"><c:out value="${errors[f]}"/></div></div></c:forEach><div class="col-md-4"><label>Gender</label><select class="form-select" name="gender"><c:forEach items="${['MALE','FEMALE','OTHER']}" var="x"><option ${patientForm.gender==x?'selected':''}><c:out value="${x}"/></option></c:forEach></select></div><div class="col-md-4"><label>Blood group</label><select class="form-select" name="bloodGroup"><c:forEach items="${['A+','A-','B+','B-','AB+','AB-','O+','O-','UNKNOWN']}" var="x"><option ${patientForm.bloodGroup==x?'selected':''}><c:out value="${x}"/></option></c:forEach></select></div><div class="col-md-4"><label>Status</label><select class="form-select" name="status"><option ${patientForm.status=='ACTIVE'?'selected':''}>ACTIVE</option><option ${patientForm.status=='INACTIVE'?'selected':''}>INACTIVE</option></select></div></div><h2 class="h5 mt-4">Contact Information</h2><div class="row g-3"><div class="col-md-6"><label>Phone</label><input class="form-control" name="phone" maxlength="20" required value="<c:out value='${patientForm.phone}'/>"><div class="text-danger"><c:out value="${errors.phone}"/></div></div><div class="col-md-6"><label>Email</label><input class="form-control" type="email" name="email" maxlength="150" value="<c:out value='${patientForm.email}'/>"><div class="text-danger"><c:out value="${errors.email}"/></div></div><div class="col-12"><label>Address</label><textarea class="form-control" name="address" maxlength="500"><c:out value="${patientForm.address}"/></textarea></div></div><h2 class="h5 mt-4">Emergency Contact</h2><div class="row g-3"><div class="col-md-6"><input class="form-control" name="emergencyContactName" maxlength="150" placeholder="Contact name" value="<c:out value='${patientForm.emergencyContactName}'/>"></div><div class="col-md-6"><input class="form-control" name="emergencyContactPhone" maxlength="20" placeholder="Contact phone" value="<c:out value='${patientForm.emergencyContactPhone}'/>"></div></div><h2 class="h5 mt-4">Login Account</h2><c:if test="${not linkedAccount}"><div class="form-check"><input id="login" class="form-check-input" type="checkbox" name="createLoginAccount" value="true" ${patientForm.createLoginAccount?'checked':''}><label for="login">Create login account</label></div></c:if><c:if test="${linkedAccount}"><input type="hidden" name="createLoginAccount" value="false"></c:if><div id="account" class="row g-3 mt-1"><div class="col-md-4"><label>Username</label><input class="form-control" name="username" maxlength="50" value="<c:out value='${patientForm.username}'/>"><div class="text-danger"><c:out value="${errors.username}"/></div></div><div class="col-md-4"><label>${linkedAccount?'New password (optional)':'Password'}</label><input class="form-control" type="password" name="password" maxlength="72" autocomplete="new-password"><div class="text-danger"><c:out value="${errors.password}"/></div></div><div class="col-md-4"><label>Confirm password</label><input class="form-control" type="password" name="confirmPassword" maxlength="72" autocomplete="new-password"></div></div><div class="mt-4"><button class="btn btn-primary">Save Patient</button> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/admin/patients">Cancel</a></div></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %><script>const c=document.getElementById('login'),a=document.getElementById('account');function show(){if(c)a.style.display=c.checked?'flex':'none'}if(c){c.addEventListener('change',show);show()}</script></body></html>
