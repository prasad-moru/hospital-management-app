<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Patient Management</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid px-lg-5 py-4"><div class="d-flex justify-content-between"><h1>Patient Management</h1><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/patients/create">Add Patient</a></div><c:if test="${not empty message}"><div class="alert alert-success">Patient operation completed successfully.</div></c:if><c:if test="${error=='blocked'}"><div class="alert alert-warning">Patient has a future appointment, active admission, or locked account.</div></c:if><c:if test="${error=='error'}"><div class="alert alert-danger">Operation could not be completed.</div></c:if><form class="row g-2 my-3" method="get"><div class="col"><input class="form-control" name="search" value="<c:out value='${search}'/>" placeholder="Number, name, phone, email, username..."></div><div class="col-auto"><select class="form-select" name="status"><option value="">All statuses</option><option ${status=='ACTIVE'?'selected':''}>ACTIVE</option><option ${status=='INACTIVE'?'selected':''}>INACTIVE</option></select></div><div class="col-auto"><button class="btn btn-outline-primary">Search</button></div><div class="col-auto"><a class="btn btn-link" href="${pageContext.request.contextPath}/admin/patients">Clear filters</a></div></form><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>ID</th><th>Patient Number</th><th>Name</th><th>Date of Birth</th><th>Gender</th><th>Blood Group</th><th>Phone</th><th>Email</th><th>Login Account</th><th>Status</th><th>Actions</th></tr></thead><tbody><c:forEach items="${patientPage.content}" var="p"><tr><td><c:out value="${p.patientId}"/></td><td><c:out value="${p.patientNumber}"/></td><td><c:out value="${p.fullName}"/></td><td><c:out value="${p.dateOfBirth}"/></td><td><c:out value="${p.gender}"/></td><td><c:out value="${p.bloodGroup}"/></td><td><c:out value="${p.phone}"/></td><td><c:out value="${p.email}"/></td><td><span class="badge ${empty p.userId?'bg-secondary':'bg-info'}">${empty p.userId?'None':'Linked'}</span></td><td><span class="badge ${p.status=='ACTIVE'?'bg-success':'bg-secondary'}"><c:out value="${p.status}"/></span></td><td class="text-nowrap"><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/admin/patients/view?id=${p.patientId}">View</a> <a class="btn btn-sm btn-outline-dark" href="${pageContext.request.contextPath}/admin/patients/edit?id=${p.patientId}">Edit</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/admin/patients/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="patientId" value="<c:out value='${p.patientId}'/>"><input type="hidden" name="action" value="${p.status=='ACTIVE'?'deactivate':'activate'}"><button class="btn btn-sm ${p.status=='ACTIVE'?'btn-outline-danger':'btn-outline-success'}">${p.status=='ACTIVE'?'Deactivate':'Activate'}</button></form></td></tr></c:forEach><c:if test="${empty patientPage.content}"><tr><td colspan="11" class="text-center py-5">No patients found.</td></tr></c:if></tbody></table></div><nav><ul class="pagination"><c:forEach begin="1" end="${patientPage.totalPages}" var="n"><c:url var="u" value="/admin/patients"><c:param name="page" value="${n}"/><c:param name="size" value="${patientPage.pageSize}"/><c:param name="search" value="${search}"/><c:param name="status" value="${status}"/></c:url><li class="page-item ${n==patientPage.pageNumber?'active':''}"><a class="page-link" href="${u}"><c:out value="${n}"/></a></li></c:forEach></ul></nav></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
