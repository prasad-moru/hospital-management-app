<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Patient Details</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="card shadow-sm"><div class="card-header bg-primary text-white"><h1><c:out value="${patient.fullName}"/></h1><c:out value="${patient.patientNumber}"/></div><div class="card-body"><dl class="row"><c:forEach items="${['patientId','dateOfBirth','age','gender','bloodGroup','phone','email','address','emergencyContactName','emergencyContactPhone','status','username','userStatus','createdAt','updatedAt']}" var="f"><dt class="col-sm-4"><c:out value="${f}"/></dt><dd class="col-sm-8"><c:out value="${patient[f]}"/></dd></c:forEach></dl><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/patients/edit?id=${patient.patientId}">Edit</a> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/admin/patients">Back</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/admin/patients/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="patientId" value="<c:out value='${patient.patientId}'/>"><input type="hidden" name="action" value="${patient.status=='ACTIVE'?'deactivate':'activate'}"><button class="btn btn-outline-warning">${patient.status=='ACTIVE'?'Deactivate':'Activate'}</button></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
