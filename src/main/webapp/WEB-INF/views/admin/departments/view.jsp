<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Department Details</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1><c:out value="${department.departmentName}"/></h1><dl class="row"><dt class="col-sm-3">ID</dt><dd class="col-sm-9"><c:out value="${department.departmentId}"/></dd><dt class="col-sm-3">Description</dt><dd class="col-sm-9"><c:out value="${department.description}"/></dd><dt class="col-sm-3">Location</dt><dd class="col-sm-9"><c:out value="${department.location}"/></dd><dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge ${department.status=='ACTIVE'?'bg-success':'bg-secondary'}"><c:out value="${department.status}"/></span></dd><dt class="col-sm-3">Created</dt><dd class="col-sm-9"><c:out value="${department.createdAt}"/></dd><dt class="col-sm-3">Updated</dt><dd class="col-sm-9"><c:out value="${department.updatedAt}"/></dd></dl><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/departments/edit?id=${department.departmentId}">Edit</a> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/admin/departments">Back</a><form class="d-inline" method="post" action="${pageContext.request.contextPath}/admin/departments/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="departmentId" value="<c:out value='${department.departmentId}'/>"><input type="hidden" name="action" value="${department.status=='ACTIVE'?'deactivate':'activate'}"><button class="btn btn-outline-warning">${department.status=='ACTIVE'?'Deactivate':'Activate'}</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
