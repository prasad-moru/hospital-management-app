<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Department Management</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="d-flex justify-content-between align-items-center"><div><h1>Department Management</h1><a href="${pageContext.request.contextPath}/admin/">Admin Dashboard</a></div><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/departments/create">Add Department</a></div><c:if test="${message=='created'}"><div class="alert alert-success mt-3">Department created successfully.</div></c:if><c:if test="${message=='updated'}"><div class="alert alert-success mt-3">Department updated successfully.</div></c:if><c:if test="${message=='activated'||message=='deactivated'}"><div class="alert alert-success mt-3">Department status updated.</div></c:if><c:if test="${error=='activeDoctors'}"><div class="alert alert-warning mt-3">Department cannot be deactivated while active doctors are assigned.</div></c:if><form class="row g-2 my-3" method="get"><div class="col"><input class="form-control" name="search" value="<c:out value='${search}'/>" placeholder="Search departments"></div><div class="col-auto"><button class="btn btn-outline-primary">Search</button></div></form><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>ID</th><th>Name</th><th>Description</th><th>Location</th><th>Status</th><th>Actions</th></tr></thead><tbody><c:forEach items="${departmentPage.content}" var="d"><tr><td><c:out value="${d.departmentId}"/></td><td><c:out value="${d.departmentName}"/></td><td><c:out value="${d.description}"/></td><td><c:out value="${d.location}"/></td><td><span class="badge ${d.status=='ACTIVE'?'bg-success':'bg-secondary'}"><c:out value="${d.status}"/></span></td><td class="text-nowrap"><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/admin/departments/view?id=${d.departmentId}">View</a> <a class="btn btn-sm btn-outline-dark" href="${pageContext.request.contextPath}/admin/departments/edit?id=${d.departmentId}">Edit</a><form class="d-inline" method="post" action="${pageContext.request.contextPath}/admin/departments/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="departmentId" value="<c:out value='${d.departmentId}'/>"><input type="hidden" name="action" value="${d.status=='ACTIVE'?'deactivate':'activate'}"><button class="btn btn-sm ${d.status=='ACTIVE'?'btn-outline-danger':'btn-outline-success'}">${d.status=='ACTIVE'?'Deactivate':'Activate'}</button></form></td></tr></c:forEach><c:if test="${empty departmentPage.content}"><tr><td colspan="6" class="text-center py-4">No departments found.</td></tr></c:if></tbody></table></div><nav><ul class="pagination"><c:forEach begin="1" end="${departmentPage.totalPages}" var="p"><c:url var="pageUrl" value="/admin/departments"><c:param name="page" value="${p}"/><c:param name="size" value="${departmentPage.pageSize}"/><c:param name="search" value="${search}"/></c:url><li class="page-item ${p==departmentPage.pageNumber?'active':''}"><a class="page-link" href="${pageUrl}"><c:out value="${p}"/></a></li></c:forEach></ul></nav></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
