<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>${formMode=='CREATE'?'Add':'Edit'} Department</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="card shadow-sm mx-auto" style="max-width:42rem"><div class="card-body"><h1 class="h3">${formMode=='CREATE'?'Add':'Edit'} Department</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><c:if test="${formMode=='EDIT'}"><input type="hidden" name="departmentId" value="<c:out value='${department.departmentId}'/>"></c:if><div class="mb-3"><label class="form-label">Department name *</label><input class="form-control" name="departmentName" maxlength="100" required value="<c:out value='${department.departmentName}'/>"><div class="text-danger"><c:out value="${errors.departmentName}"/></div></div><div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" maxlength="500"><c:out value="${department.description}"/></textarea><div class="text-danger"><c:out value="${errors.description}"/></div></div><div class="mb-3"><label class="form-label">Location</label><input class="form-control" name="location" maxlength="150" value="<c:out value='${department.location}'/>"><div class="text-danger"><c:out value="${errors.location}"/></div></div><div class="mb-3"><label class="form-label">Status *</label><select class="form-select" name="status"><option ${department.status=='ACTIVE'?'selected':''}>ACTIVE</option><option ${department.status=='INACTIVE'?'selected':''}>INACTIVE</option></select><div class="text-danger"><c:out value="${errors.status}"/></div></div><button class="btn btn-primary">Save</button> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/admin/departments">Cancel</a></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
