<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>${formMode=='CREATE'?'Add':'Edit'} Doctor</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %>
<main class="container py-4"><div class="card shadow-sm"><div class="card-body p-lg-4"><h1 class="h3">${formMode=='CREATE'?'Add':'Edit'} Doctor</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post" autocomplete="off"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><c:if test="${formMode=='EDIT'}"><input type="hidden" name="doctorId" value="<c:out value='${doctorForm.doctorId}'/>"></c:if>
<h2 class="h5 mt-3">Account Information</h2><div class="row g-3"><div class="col-md-6"><label class="form-label">Username *</label><input class="form-control" name="username" maxlength="50" required pattern="[A-Za-z][A-Za-z0-9._-]{3,49}" value="<c:out value='${doctorForm.username}'/>"><div class="text-danger"><c:out value="${errors.username}"/></div></div><div class="col-md-6"><label class="form-label">Email *</label><input class="form-control" type="email" name="email" maxlength="150" required value="<c:out value='${doctorForm.email}'/>"><div class="text-danger"><c:out value="${errors.email}"/></div></div><div class="col-md-6"><label class="form-label">Password ${formMode=='CREATE'?'*':''}</label><input class="form-control" type="password" name="password" minlength="8" maxlength="72" ${formMode=='CREATE'?'required':''} autocomplete="new-password"><c:if test="${formMode=='EDIT'}"><div class="form-text">Leave blank to keep the existing password.</div></c:if><div class="text-danger"><c:out value="${errors.password}"/></div></div><div class="col-md-6"><label class="form-label">Confirm password ${formMode=='CREATE'?'*':''}</label><input class="form-control" type="password" name="confirmPassword" minlength="8" maxlength="72" ${formMode=='CREATE'?'required':''} autocomplete="new-password"><div class="text-danger"><c:out value="${errors.confirmPassword}"/></div></div></div>
<h2 class="h5 mt-4">Professional Information</h2><div class="row g-3"><div class="col-md-6"><label class="form-label">Department *</label><select class="form-select" name="departmentId" required><option value="">Select a department</option><c:forEach items="${departments}" var="dep"><option value="<c:out value='${dep.departmentId}'/>" ${doctorForm.departmentId==dep.departmentId?'selected':''}><c:out value="${dep.departmentName}"/><c:if test="${dep.status=='INACTIVE'}"> (INACTIVE - current only)</c:if></option></c:forEach></select><div class="text-danger"><c:out value="${errors.departmentId}"/></div></div><div class="col-md-6"><label class="form-label">Registration number *</label><input class="form-control" name="registrationNumber" maxlength="50" required value="<c:out value='${doctorForm.registrationNumber}'/>"><div class="text-danger"><c:out value="${errors.registrationNumber}"/></div></div><div class="col-md-6"><label class="form-label">First name *</label><input class="form-control" name="firstName" maxlength="100" required value="<c:out value='${doctorForm.firstName}'/>"><div class="text-danger"><c:out value="${errors.firstName}"/></div></div><div class="col-md-6"><label class="form-label">Last name *</label><input class="form-control" name="lastName" maxlength="100" required value="<c:out value='${doctorForm.lastName}'/>"><div class="text-danger"><c:out value="${errors.lastName}"/></div></div><div class="col-md-6"><label class="form-label">Specialization *</label><input class="form-control" name="specialization" maxlength="150" required value="<c:out value='${doctorForm.specialization}'/>"><div class="text-danger"><c:out value="${errors.specialization}"/></div></div><div class="col-md-6"><label class="form-label">Qualification *</label><input class="form-control" name="qualification" maxlength="200" required value="<c:out value='${doctorForm.qualification}'/>"><div class="text-danger"><c:out value="${errors.qualification}"/></div></div></div>
<h2 class="h5 mt-4">Contact and Fee</h2><div class="row g-3"><div class="col-md-4"><label class="form-label">Phone *</label><input class="form-control" name="phone" maxlength="20" required value="<c:out value='${doctorForm.phone}'/>"><div class="text-danger"><c:out value="${errors.phone}"/></div></div><div class="col-md-4"><label class="form-label">Consultation fee *</label><input class="form-control" type="number" name="consultationFee" min="0" max="1000000" step="0.01" required value="<c:out value='${doctorForm.consultationFee}'/>"><div class="text-danger"><c:out value="${errors.consultationFee}"/></div></div><div class="col-md-4"><label class="form-label">Status *</label><select class="form-select" name="status"><option value="ACTIVE" ${doctorForm.status=='ACTIVE'?'selected':''}>ACTIVE</option><option value="INACTIVE" ${doctorForm.status=='INACTIVE'?'selected':''}>INACTIVE</option></select><div class="text-danger"><c:out value="${errors.status}"/></div></div></div><div class="mt-4"><button class="btn btn-primary">Save Doctor</button> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/admin/doctors">Cancel</a></div></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
