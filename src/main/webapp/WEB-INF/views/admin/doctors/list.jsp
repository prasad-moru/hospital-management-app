<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Doctor Management</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %>
<main class="container-fluid px-lg-5 py-4"><div class="d-flex justify-content-between align-items-center"><div><h1>Doctor Management</h1><a href="${pageContext.request.contextPath}/admin/">Admin Dashboard</a></div><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/doctors/create">Add Doctor</a></div>
<c:if test="${message=='created'}"><div class="alert alert-success mt-3">Doctor created successfully.</div></c:if><c:if test="${message=='updated'}"><div class="alert alert-success mt-3">Doctor updated successfully.</div></c:if><c:if test="${message=='activated'||message=='deactivated'}"><div class="alert alert-success mt-3">Doctor status updated successfully.</div></c:if><c:if test="${error=='blocked'}"><div class="alert alert-warning mt-3">The status change is blocked by account, department, appointment, or schedule rules.</div></c:if><c:if test="${error=='error'}"><div class="alert alert-danger mt-3">The operation could not be completed. Please try again.</div></c:if>
<form class="row g-2 my-3" method="get" action="${pageContext.request.contextPath}/admin/doctors"><div class="col-lg-5"><label class="visually-hidden" for="search">Search</label><input id="search" class="form-control" name="search" maxlength="150" value="<c:out value='${search}'/>" placeholder="Name, registration, specialization, username..."></div><div class="col-md-3"><select class="form-select" name="departmentId"><option value="">All departments</option><c:forEach items="${departments}" var="dep"><option value="<c:out value='${dep.departmentId}'/>" ${departmentId==dep.departmentId?'selected':''}><c:out value="${dep.departmentName}"/></option></c:forEach></select></div><div class="col-md-2"><select class="form-select" name="status"><option value="">All statuses</option><option value="ACTIVE" ${status=='ACTIVE'?'selected':''}>ACTIVE</option><option value="INACTIVE" ${status=='INACTIVE'?'selected':''}>INACTIVE</option></select></div><div class="col-auto"><button class="btn btn-outline-primary">Filter / Search</button></div><div class="col-auto"><a class="btn btn-link" href="${pageContext.request.contextPath}/admin/doctors">Clear filters</a></div></form>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>ID</th><th>Registration No.</th><th>Doctor Name</th><th>Department</th><th>Specialization</th><th>Username</th><th>Phone</th><th>Consultation Fee</th><th>Status</th><th>Actions</th></tr></thead><tbody><c:forEach items="${doctorPage.content}" var="d"><tr><td><c:out value="${d.doctorId}"/></td><td><c:out value="${d.registrationNumber}"/></td><td><c:out value="${d.fullName}"/></td><td><c:out value="${d.departmentName}"/></td><td><c:out value="${d.specialization}"/></td><td><c:out value="${d.username}"/></td><td><c:out value="${d.phone}"/></td><td><fmt:formatNumber value="${d.consultationFee}" minFractionDigits="2" maxFractionDigits="2"/></td><td><span class="badge ${d.status=='ACTIVE'?'bg-success':'bg-secondary'}"><c:out value="${d.status}"/></span></td><td class="text-nowrap"><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/admin/doctors/view?id=${d.doctorId}">View</a> <a class="btn btn-sm btn-outline-dark" href="${pageContext.request.contextPath}/admin/doctors/edit?id=${d.doctorId}">Edit</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/admin/doctors/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="doctorId" value="<c:out value='${d.doctorId}'/>"><input type="hidden" name="action" value="${d.status=='ACTIVE'?'deactivate':'activate'}"><button class="btn btn-sm ${d.status=='ACTIVE'?'btn-outline-danger':'btn-outline-success'}">${d.status=='ACTIVE'?'Deactivate':'Activate'}</button></form></td></tr></c:forEach><c:if test="${empty doctorPage.content}"><tr><td colspan="10" class="text-center py-5">No doctors match the selected filters.</td></tr></c:if></tbody></table></div>
<c:if test="${doctorPage.totalPages>1}"><nav aria-label="Doctor pages"><ul class="pagination"><c:forEach begin="1" end="${doctorPage.totalPages}" var="p"><c:url var="pageUrl" value="/admin/doctors"><c:param name="page" value="${p}"/><c:param name="size" value="${doctorPage.pageSize}"/><c:param name="search" value="${search}"/><c:param name="departmentId" value="${departmentId}"/><c:param name="status" value="${status}"/></c:url><li class="page-item ${p==doctorPage.pageNumber?'active':''}"><a class="page-link" href="${pageUrl}"><c:out value="${p}"/></a></li></c:forEach></ul></nav></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
