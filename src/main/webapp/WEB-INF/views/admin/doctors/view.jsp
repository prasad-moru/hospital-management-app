<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Doctor Details</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><div class="card shadow-sm"><div class="card-header bg-primary text-white"><h1 class="h3 mb-1"><c:out value="${doctor.fullName}"/></h1><span><c:out value="${doctor.registrationNumber}"/></span></div><div class="card-body"><div class="row"><div class="col-md-6"><h2 class="h5">Professional profile</h2><dl class="row"><dt class="col-sm-5">Doctor ID</dt><dd class="col-sm-7"><c:out value="${doctor.doctorId}"/></dd><dt class="col-sm-5">Department</dt><dd class="col-sm-7"><c:out value="${doctor.departmentName}"/></dd><dt class="col-sm-5">Specialization</dt><dd class="col-sm-7"><c:out value="${doctor.specialization}"/></dd><dt class="col-sm-5">Qualification</dt><dd class="col-sm-7"><c:out value="${doctor.qualification}"/></dd><dt class="col-sm-5">Phone</dt><dd class="col-sm-7"><c:out value="${doctor.phone}"/></dd><dt class="col-sm-5">Consultation fee</dt><dd class="col-sm-7"><fmt:formatNumber value="${doctor.consultationFee}" minFractionDigits="2" maxFractionDigits="2"/></dd><dt class="col-sm-5">Doctor status</dt><dd class="col-sm-7"><span class="badge ${doctor.status=='ACTIVE'?'bg-success':'bg-secondary'}"><c:out value="${doctor.status}"/></span></dd></dl></div><div class="col-md-6"><h2 class="h5">Account details</h2><dl class="row"><dt class="col-sm-5">Username</dt><dd class="col-sm-7"><c:out value="${doctor.username}"/></dd><dt class="col-sm-5">Email</dt><dd class="col-sm-7"><c:out value="${doctor.email}"/></dd><dt class="col-sm-5">Account status</dt><dd class="col-sm-7"><span class="badge ${doctor.userStatus=='ACTIVE'?'bg-success':doctor.userStatus=='LOCKED'?'bg-danger':'bg-secondary'}"><c:out value="${doctor.userStatus}"/></span></dd><dt class="col-sm-5">Created</dt><dd class="col-sm-7"><c:out value="${doctor.createdAt}"/></dd><dt class="col-sm-5">Updated</dt><dd class="col-sm-7"><c:out value="${doctor.updatedAt}"/></dd></dl></div></div><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/doctors/edit?id=${doctor.doctorId}">Edit</a> <a class="btn btn-outline-secondary" href="${pageContext.request.contextPath}/admin/doctors">Back to Doctor Management</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/admin/doctors/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="doctorId" value="<c:out value='${doctor.doctorId}'/>"><input type="hidden" name="action" value="${doctor.status=='ACTIVE'?'deactivate':'activate'}"><button class="btn ${doctor.status=='ACTIVE'?'btn-outline-danger':'btn-outline-success'}">${doctor.status=='ACTIVE'?'Deactivate':'Activate'}</button></form></div></div></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
