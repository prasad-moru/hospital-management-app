<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Rooms</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><h1>Rooms</h1><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/rooms/create">Add Room</a><table class="table"><thead><tr><th>ID</th><th>Room</th><th>Type</th><th>Floor</th><th>Department</th><th>Rate</th><th>Beds</th><th>Available</th><th>Status</th><th></th></tr></thead><tbody><c:forEach items="${roomPage.content}" var="r"><tr><td>${r.roomId}</td><td><c:out value="${r.roomNumber}"/></td><td>${r.roomType}</td><td>${r.floorNumber}</td><td><c:out value="${r.departmentName}"/></td><td>₹${r.dailyRate}</td><td>${r.totalBeds}</td><td>${r.availableBeds}</td><td>${r.status}</td><td><a href="${pageContext.request.contextPath}/admin/rooms/view?id=${r.roomId}">View</a></td></tr></c:forEach><c:if test="${empty roomPage.content}"><tr><td colspan="10">No rooms found.</td></tr></c:if></tbody></table><c:if test="${roomPage.totalPages>0}">Page ${roomPage.pageNumber} of ${roomPage.totalPages}</c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
