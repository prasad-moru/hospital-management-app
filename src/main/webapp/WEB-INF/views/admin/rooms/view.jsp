<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Room</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Room <c:out value="${room.roomNumber}"/></h1><p>${room.roomType}, floor ${room.floorNumber}, ₹${room.dailyRate}/day, ${room.status}</p><p>Total beds ${room.totalBeds}; available ${room.availableBeds}</p><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/rooms/edit?id=${room.roomId}">Edit</a><form method="post" action="${pageContext.request.contextPath}/admin/rooms/status"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="roomId" value="${room.roomId}"><button name="action" value="activate">Activate</button><button name="action" value="deactivate">Deactivate</button><button name="action" value="maintenance">Maintenance</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
