<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Room</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>${formMode=='CREATE'?'Add':'Edit'} Room</h1><form method="post"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="roomId" value="${roomForm.roomId}"><input class="form-control mb-2" name="roomNumber" value="<c:out value='${roomForm.roomNumber}'/>" placeholder="Room number" required><select class="form-select mb-2" name="roomType"><c:forEach items="${['GENERAL','SEMI_PRIVATE','PRIVATE','ICU','EMERGENCY','MATERNITY','PEDIATRIC','OTHER']}" var="t"><option ${roomForm.roomType==t?'selected':''}><c:out value="${t}"/></option></c:forEach></select><input class="form-control mb-2" name="floorNumber" type="number" value="${roomForm.floorNumber}" placeholder="Floor" required><input class="form-control mb-2" name="departmentId" type="number" value="${roomForm.departmentId}" placeholder="Department ID optional"><input class="form-control mb-2" name="dailyRate" type="number" min="0" step="0.01" value="${roomForm.dailyRate}" required><select class="form-select mb-2" name="status"><option>ACTIVE</option><option>INACTIVE</option><option>MAINTENANCE</option></select><button class="btn btn-primary">Save</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
