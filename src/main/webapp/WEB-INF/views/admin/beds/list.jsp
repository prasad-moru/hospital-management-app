<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Beds</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><div class="d-flex justify-content-between"><h1>Beds</h1><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/beds/create">Add Bed</a></c:if></div><form class="row g-2 my-3"><div class="col"><input class="form-control" name="search" value="<c:out value='${param.search}'/>" placeholder="Room or bed"></div><div class="col"><input class="form-control" type="number" name="roomId" value="<c:out value='${param.roomId}'/>" placeholder="Room ID"></div><div class="col"><select class="form-select" name="status"><option value="">All statuses</option><option>AVAILABLE</option><option>OCCUPIED</option><option>MAINTENANCE</option><option>INACTIVE</option></select></div><div class="col-auto"><button class="btn btn-outline-primary">Filter</button></div></form><table class="table"><thead><tr><th>ID</th><th>Room</th><th>Bed</th><th>Type</th><th>Rate</th><th>Status</th><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'}"><th>Current patient</th></c:if><th></th></tr></thead><tbody><c:forEach items="${bedPage.content}" var="b"><tr><td>${b.bedId}</td><td><c:out value="${b.roomNumber}"/></td><td><c:out value="${b.bedNumber}"/></td><td>${b.roomType}</td><td>₹${b.dailyRate}</td><td>${b.status}</td><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'}"><td><c:out value="${b.currentPatientName}"/></td></c:if><td><a href="${pageContext.request.contextPath}/admin/beds/view?id=${b.bedId}">View</a></td></tr></c:forEach><c:if test="${empty bedPage.content}"><tr><td colspan="8">No beds found.</td></tr></c:if></tbody></table><c:if test="${bedPage.totalPages>0}">Page ${bedPage.pageNumber} of ${bedPage.totalPages}</c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
