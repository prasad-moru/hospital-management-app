<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Bed</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Room <c:out value="${bed.roomNumber}"/> / Bed <c:out value="${bed.bedNumber}"/></h1><p>${bed.roomType}; ₹${bed.dailyRate}/day; ${bed.status}</p><c:if test="${sessionScope.authenticatedUser.roleName=='ADMIN'}"><p>Current patient: <c:out value="${bed.currentPatientName}"/></p><a class="btn btn-primary" href="${pageContext.request.contextPath}/admin/beds/edit?id=${bed.bedId}">Edit</a><form method="post" action="${pageContext.request.contextPath}/admin/beds/status"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="bedId" value="${bed.bedId}"><button name="action" value="available">Available</button><button name="action" value="maintenance">Maintenance</button><button name="action" value="deactivate">Inactive</button></form></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
