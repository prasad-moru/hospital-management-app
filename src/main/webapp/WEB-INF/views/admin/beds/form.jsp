<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Bed</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>${formMode=='CREATE'?'Add':'Edit'} Bed</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post"><input type="hidden" name="csrfToken" value="${sessionScope.csrfToken}"><input type="hidden" name="bedId" value="${bedForm.bedId}"><label class="form-label">Room ID</label><input class="form-control" type="number" min="1" name="roomId" value="${bedForm.roomId}" required><label class="form-label mt-2">Bed number</label><input class="form-control" name="bedNumber" value="<c:out value='${bedForm.bedNumber}'/>" required><label class="form-label mt-2">Status</label><select class="form-select" name="status"><option>AVAILABLE</option><option>MAINTENANCE</option><option>INACTIVE</option></select><p class="text-muted">OCCUPIED is controlled only by admission transactions.</p><button class="btn btn-primary">Save</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
