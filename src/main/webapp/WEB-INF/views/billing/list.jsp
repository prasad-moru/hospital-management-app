<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Billing and Payments</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container-fluid py-4"><div class="d-flex justify-content-between"><h1>Billing and Payments</h1><c:if test="${sessionScope.authenticatedUser.roleName!='PATIENT'}"><a class="btn btn-primary" href="${pageContext.request.contextPath}/billing/create">Create Bill</a></c:if></div><form class="row g-2 my-3"><div class="col-md-4"><input class="form-control" name="search" value="<c:out value='${param.search}'/>" placeholder="Bill, patient, doctor or status"></div><div class="col"><input class="form-control" type="date" name="dateFrom" value="<c:out value='${param.dateFrom}'/>"></div><div class="col"><input class="form-control" type="date" name="dateTo" value="<c:out value='${param.dateTo}'/>"></div><div class="col"><select class="form-select" name="status"><option value="">All statuses</option><c:forEach items="${['UNPAID','PARTIALLY_PAID','PAID','CANCELLED','REFUNDED']}" var="s"><option ${param.status==s?'selected':''}><c:out value="${s}"/></option></c:forEach></select></div><div class="col-auto"><button class="btn btn-outline-primary">Filter</button></div></form><div class="table-responsive"><table class="table table-striped"><thead><tr><th>ID</th><th>Bill Number</th><th>Date</th><th>Patient</th><th>Appointment</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th><th>Actions</th></tr></thead><tbody><c:forEach items="${billPage.content}" var="b"><tr><td><c:out value="${b.billId}"/></td><td><c:out value="${b.billNumber}"/></td><td><c:out value="${b.billDate}"/></td><td><c:out value="${b.patientName}"/></td><td><c:out value="${b.appointmentId}"/></td><td>₹<c:out value="${b.totalAmount}"/></td><td>₹<c:out value="${b.paidAmount}"/></td><td>₹<c:out value="${b.balanceAmount}"/></td><td><span class="badge bg-secondary"><c:out value="${b.status}"/></span></td><td><a class="btn btn-sm btn-outline-primary" href="${pageContext.request.contextPath}/billing/view?id=${b.billId}">View</a> <a class="btn btn-sm btn-outline-secondary" href="${pageContext.request.contextPath}/billing/print?id=${b.billId}">Print</a><c:if test="${b.status=='UNPAID'&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='BILLING_STAFF')}"> <a class="btn btn-sm btn-primary" href="${pageContext.request.contextPath}/billing/edit?id=${b.billId}">Edit</a></c:if></td></tr></c:forEach><c:if test="${empty billPage.content}"><tr><td colspan="10" class="text-center py-4">No bills found.</td></tr></c:if></tbody></table></div><c:if test="${!billPage.first}"><a class="btn btn-outline-secondary" href="?page=${billPage.pageNumber-1}&amp;size=${billPage.pageSize}&amp;search=${param.search}">Previous</a></c:if><span class="mx-2">Page <c:out value="${billPage.pageNumber}"/> of <c:out value="${billPage.totalPages}"/></span><c:if test="${!billPage.last}"><a class="btn btn-outline-secondary" href="?page=${billPage.pageNumber+1}&amp;size=${billPage.pageSize}&amp;search=${param.search}">Next</a></c:if></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
