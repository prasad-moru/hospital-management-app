<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Payment Receipt</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/billing-print.css"></head><body><header><h1>Online Hospital Management System</h1><h2>Payment Receipt</h2></header><dl><dt>Payment number</dt><dd><c:out value="${payment.paymentNumber}"/></dd><dt>Bill number</dt><dd><c:out value="${payment.billNumber}"/></dd><dt>Patient</dt><dd><c:out value="${payment.patientName}"/></dd><dt>Date</dt><dd><c:out value="${payment.paymentDate}"/></dd><dt>Amount</dt><dd>₹<c:out value="${payment.amount}"/></dd><dt>Method</dt><dd><c:out value="${payment.paymentMethod}"/></dd><dt>External reference</dt><dd><c:out value="${payment.transactionReference}"/></dd><dt>Received by</dt><dd><c:out value="${payment.receivedByUsername}"/></dd><dt>Status</dt><dd><c:out value="${payment.status}"/></dd></dl><div class="signature">Authorized signature: ____________________</div><button id="print-document" class="no-print">Print</button><script src="${pageContext.request.contextPath}/assets/js/billing-print.js" defer></script></body></html>
