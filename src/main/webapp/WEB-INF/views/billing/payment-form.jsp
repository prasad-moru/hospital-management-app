<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Record Payment</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Record Payment</h1><p>Bill <strong><c:out value="${bill.billNumber}"/></strong> — <c:out value="${bill.patientName}"/></p><p>Total ₹<c:out value="${bill.totalAmount}"/> | Paid ₹<c:out value="${bill.paidAmount}"/> | Balance ₹<c:out value="${bill.balanceAmount}"/></p><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post" class="card card-body"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="billId" value="${bill.billId}"><label class="form-label">Amount</label><input class="form-control" name="amount" type="number" min="0.01" max="${bill.balanceAmount}" step="0.01" value="<c:out value='${paymentForm.amount}'/>" required><label class="form-label mt-2">Method</label><select class="form-select" name="paymentMethod" required><c:forEach items="${['CASH','CARD','UPI','BANK_TRANSFER','INSURANCE']}" var="m"><option ${paymentForm.paymentMethod==m?'selected':''}><c:out value="${m}"/></option></c:forEach></select><label class="form-label mt-2">External transaction reference</label><input class="form-control" name="transactionReference" maxlength="150" value="<c:out value='${paymentForm.transactionReference}'/>"><p class="text-muted mt-2">Never enter a card number, CVV, PIN, UPI PIN, bank password or other payment credentials.</p><button class="btn btn-primary">Record Payment</button></form></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
