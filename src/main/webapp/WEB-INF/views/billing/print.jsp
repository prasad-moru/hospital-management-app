<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><title>Invoice</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/billing-print.css"></head><body><header><h1>Online Hospital Management System</h1><h2>Invoice <c:out value="${bill.billNumber}"/></h2></header><p>Patient: <c:out value="${bill.patientName}"/> (<c:out value="${bill.patientNumber}"/>)</p><p>Appointment: <c:out value="${bill.appointmentId}"/> | Doctor: <c:out value="${bill.doctorName}"/> | Date: <c:out value="${bill.billDate}"/></p><table><thead><tr><th>Type</th><th>Description</th><th>Quantity</th><th>Unit price</th><th>Total</th></tr></thead><tbody><c:forEach items="${bill.items}" var="i"><tr><td><c:out value="${i.itemType}"/></td><td><c:out value="${i.description}"/></td><td><c:out value="${i.quantity}"/></td><td>₹<c:out value="${i.unitPrice}"/></td><td>₹<c:out value="${i.lineTotal}"/></td></tr></c:forEach></tbody></table><div class="summary">Subtotal ₹<c:out value="${bill.subtotal}"/><br>Tax ₹<c:out value="${bill.taxAmount}"/><br>Discount ₹<c:out value="${bill.discountAmount}"/><br>Total ₹<c:out value="${bill.totalAmount}"/><br>Paid ₹<c:out value="${bill.paidAmount}"/><br>Balance ₹<c:out value="${bill.balanceAmount}"/><br>Status <c:out value="${bill.status}"/></div><button id="print-document" class="no-print">Print</button><script src="${pageContext.request.contextPath}/assets/js/billing-print.js" defer></script></body></html>
