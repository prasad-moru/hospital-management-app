<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Bill</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>${formMode=='CREATE'?'Create':'Edit'} Bill</h1><c:if test="${not empty errorMessage}"><div class="alert alert-danger"><c:out value="${errorMessage}"/></div></c:if><form method="post" id="billingForm"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="billId" value="<c:out value='${billForm.billId}'/>"><div class="row g-3"><div class="col"><label class="form-label">Patient ID</label><input class="form-control" type="number" min="1" name="patientId" value="<c:out value='${billForm.patientId}'/>" ${formMode=='EDIT'?'readonly':''} required><div class="text-danger"><c:out value="${errors.patientId}"/></div></div><div class="col"><label class="form-label">Appointment ID (optional)</label><input class="form-control" type="number" min="1" name="appointmentId" value="<c:out value='${billForm.appointmentId}'/>" ${formMode=='EDIT'?'readonly':''}></div><div class="col"><label class="form-label">Tax</label><input id="taxAmount" class="form-control" type="number" min="0" step="0.01" name="taxAmount" value="<c:out value='${billForm.taxAmount}'/>"></div><div class="col"><label class="form-label">Discount</label><input id="discountAmount" class="form-control" type="number" min="0" step="0.01" name="discountAmount" value="<c:out value='${billForm.discountAmount}'/>"></div></div><h2 class="h5 mt-4">Bill items</h2><div id="billItems" data-max="50"><c:forEach items="${billForm.items}" var="i" varStatus="v"><div class="bill-item card card-body mb-2"><div class="row g-2"><div class="col"><select class="form-select item-type" name="items[${v.index}].itemType"><c:forEach items="${['CONSULTATION','ROOM','MEDICINE','LAB_TEST','PROCEDURE','OTHER']}" var="t"><option ${i.itemType==t?'selected':''}><c:out value="${t}"/></option></c:forEach></select></div><div class="col-md-4"><input class="form-control description" name="items[${v.index}].description" value="<c:out value='${i.description}'/>" placeholder="Description" required></div><div class="col"><input class="form-control quantity" type="number" min="0.01" step="0.01" name="items[${v.index}].quantity" value="<c:out value='${i.quantity}'/>" required></div><div class="col"><input class="form-control unit-price" type="number" min="0" step="0.01" name="items[${v.index}].unitPrice" value="<c:out value='${i.unitPrice}'/>" required></div><div class="col"><span class="line-total form-control">0.00</span></div><div class="col-auto"><button type="button" class="remove-item btn btn-outline-danger">Remove</button></div></div></div></c:forEach></div><button id="addBillItem" type="button" class="btn btn-outline-primary">Add Item</button><div class="mt-3 text-end"><strong>Preview subtotal: ₹<span id="previewSubtotal">0.00</span><br>Estimated total: ₹<span id="previewTotal">0.00</span></strong><p class="text-muted">The server recalculates all final amounts.</p></div><button class="btn btn-primary">Save Bill</button></form></main><script src="${pageContext.request.contextPath}/assets/js/billing.js" defer></script><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
