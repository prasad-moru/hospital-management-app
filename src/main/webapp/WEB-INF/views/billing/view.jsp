<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Bill</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"></head><body><%@ include file="/WEB-INF/views/common/header.jsp" %><main class="container py-4"><h1>Bill <c:out value="${bill.billNumber}"/></h1><p><strong>Patient:</strong> <c:out value="${bill.patientName}"/> (<c:out value="${bill.patientNumber}"/>) | <strong>Date:</strong> <c:out value="${bill.billDate}"/> | <strong>Status:</strong> <c:out value="${bill.status}"/></p><p><strong>Appointment:</strong> <c:out value="${bill.appointmentId}"/> <c:out value="${bill.appointmentDate}"/> | <strong>Doctor:</strong> <c:out value="${bill.doctorName}"/> | <strong>Department:</strong> <c:out value="${bill.departmentName}"/></p><table class="table table-bordered"><thead><tr><th>Type</th><th>Description</th><th>Quantity</th><th>Unit price</th><th>Line total</th></tr></thead><tbody><c:forEach items="${bill.items}" var="i"><tr><td><c:out value="${i.itemType}"/></td><td><c:out value="${i.description}"/></td><td><c:out value="${i.quantity}"/></td><td>₹<c:out value="${i.unitPrice}"/></td><td>₹<c:out value="${i.lineTotal}"/></td></tr></c:forEach></tbody></table><div class="text-end"><p>Subtotal ₹<c:out value="${bill.subtotal}"/><br>Tax ₹<c:out value="${bill.taxAmount}"/><br>Discount ₹<c:out value="${bill.discountAmount}"/><br><strong>Total ₹<c:out value="${bill.totalAmount}"/></strong><br>Paid ₹<c:out value="${bill.paidAmount}"/><br><strong>Balance ₹<c:out value="${bill.balanceAmount}"/></strong></p></div><h2 class="h4">Payment history</h2><table class="table"><thead><tr><th>Number</th><th>Date</th><th>Amount</th><th>Method</th><th>Status</th><th>Receipt</th><th></th></tr></thead><tbody><c:forEach items="${bill.payments}" var="p"><tr><td><c:out value="${p.paymentNumber}"/></td><td><c:out value="${p.paymentDate}"/></td><td>₹<c:out value="${p.amount}"/></td><td><c:out value="${p.paymentMethod}"/></td><td><c:out value="${p.status}"/></td><td><a href="${pageContext.request.contextPath}/billing/payment/receipt?id=${p.paymentId}">Print Receipt</a></td><td><c:if test="${p.status=='SUCCESS'&&sessionScope.authenticatedUser.roleName=='ADMIN'}"><form method="post" action="${pageContext.request.contextPath}/billing/payment/refund"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="paymentId" value="${p.paymentId}"><input type="hidden" name="billId" value="${bill.billId}"><button class="btn btn-sm btn-warning">Refund</button></form></c:if></td></tr></c:forEach><c:if test="${empty bill.payments}"><tr><td colspan="7">No payments recorded.</td></tr></c:if></tbody></table><a class="btn btn-secondary" href="${pageContext.request.contextPath}/billing">Back</a> <a class="btn btn-outline-primary" href="${pageContext.request.contextPath}/billing/print?id=${bill.billId}">Print Invoice</a><c:if test="${bill.status=='UNPAID'&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='BILLING_STAFF')}"> <a class="btn btn-primary" href="${pageContext.request.contextPath}/billing/edit?id=${bill.billId}">Edit</a> <form class="d-inline" method="post" action="${pageContext.request.contextPath}/billing/status"><input type="hidden" name="csrfToken" value="<c:out value='${sessionScope.csrfToken}'/>"><input type="hidden" name="billId" value="${bill.billId}"><button class="btn btn-danger" name="action" value="cancel">Cancel</button></form></c:if><c:if test="${bill.balanceAmount>0&&(sessionScope.authenticatedUser.roleName=='ADMIN'||sessionScope.authenticatedUser.roleName=='BILLING_STAFF'||sessionScope.authenticatedUser.roleName=='RECEPTIONIST')}"> <a class="btn btn-success" href="${pageContext.request.contextPath}/billing/payment/create?billId=${bill.billId}">Record Payment</a></c:if><p class="text-muted mt-3">Created <c:out value="${bill.createdAt}"/>; updated <c:out value="${bill.updatedAt}"/></p></main><%@ include file="/WEB-INF/views/common/footer.jsp" %></body></html>
