<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Doctor and Department Report</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="${pageContext.request.contextPath}/assets/css/reports-print.css" rel="stylesheet"></head><body><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/header.jsp" %></c:if><main class="container py-4"><h1>Doctor and Department Report</h1><p class="print-only">Online Hospital Management System</p><%@ include file="filter.jspf" %><c:if test="${empty printMode}"><p><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=doctors&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}&amp;doctorId=${filter.doctorId}">Export CSV</a> <a class="btn btn-outline-secondary" href="?print=true&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}&amp;doctorId=${filter.doctorId}">Print view</a></p></c:if><table class="table table-striped"><thead><tr><th>Department</th><th>Total doctors</th><th>Active doctors</th><th>Appointments</th></tr></thead><tbody><c:forEach items="${summary}" var="x"><tr><td><c:out value="${x.departmentName}"/></td><td>${x.doctorCount}</td><td>${x.activeDoctorCount}</td><td>${x.appointmentCount}</td></tr></c:forEach><c:if test="${empty summary}"><tr><td colspan="4" class="text-center">No doctor/department data.</td></tr></c:if></tbody></table></main><c:if test="${printMode}"><script src="${pageContext.request.contextPath}/assets/js/reports-print.js" defer></script></c:if><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/footer.jsp" %></c:if></body></html>
