<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Appointment Report</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="${pageContext.request.contextPath}/assets/css/reports-print.css" rel="stylesheet"></head><body>
<c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/header.jsp" %></c:if><main class="container py-4"><h1>Appointment Report</h1><p class="print-only">Online Hospital Management System</p><%@ include file="filter.jspf" %>
<c:if test="${empty printMode}"><div class="mb-3"><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=appointments&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}&amp;doctorId=${filter.doctorId}">Export CSV</a> <a class="btn btn-outline-secondary" href="?print=true&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}&amp;doctorId=${filter.doctorId}">Print view</a></div></c:if>
<h2 class="h4">By status</h2><div class="table-responsive"><table class="table table-striped"><thead><tr><th>Status</th><th>Appointments</th></tr></thead><tbody><c:forEach items="${summary}" var="x"><tr><td><c:out value="${x.status}"/></td><td><c:out value="${x.appointmentCount}"/></td></tr></c:forEach><c:if test="${empty summary}"><tr><td colspan="2" class="text-center">No appointment data for this period.</td></tr></c:if></tbody></table></div>
<h2 class="h4">Daily trend</h2><table class="table"><thead><tr><th>Date</th><th>Appointments</th></tr></thead><tbody><c:forEach items="${trend}" var="x"><tr><td><c:out value="${x.reportDate}"/></td><td><c:out value="${x.appointmentCount}"/></td></tr></c:forEach><c:if test="${empty trend}"><tr><td colspan="2">No trend data.</td></tr></c:if></tbody></table>
<h2 class="h4">By department</h2><table class="table"><thead><tr><th>Department</th><th>Doctors</th><th>Active</th><th>Appointments</th></tr></thead><tbody><c:forEach items="${doctorSummary}" var="x"><tr><td><c:out value="${x.departmentName}"/></td><td>${x.doctorCount}</td><td>${x.activeDoctorCount}</td><td>${x.appointmentCount}</td></tr></c:forEach></tbody></table>
</main><c:if test="${printMode}"><script src="${pageContext.request.contextPath}/assets/js/reports-print.js" defer></script></c:if><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/footer.jsp" %></c:if></body></html>
