<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Billing and Revenue Report</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="${pageContext.request.contextPath}/assets/css/reports-print.css" rel="stylesheet"></head><body><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/header.jsp" %></c:if><main class="container py-4"><h1>Billing and Revenue Report</h1><p class="print-only">Online Hospital Management System</p><%@ include file="filter.jspf" %><c:if test="${empty printMode}"><p><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=billing&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}">Export billing</a> <a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=revenue&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}">Export revenue</a> <a class="btn btn-outline-secondary" href="?print=true&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}">Print view</a></p></c:if>
<h2 class="h4">Billing by status</h2><div class="table-responsive"><table class="table table-striped"><thead><tr><th>Status</th><th>Bills</th><th>Total</th><th>Paid</th><th>Balance</th></tr></thead><tbody><c:forEach items="${summary}" var="x"><tr><td><c:out value="${x.status}"/></td><td>${x.billCount}</td><td>₹<fmt:formatNumber value="${x.totalAmount}" minFractionDigits="2" maxFractionDigits="2"/></td><td>₹<fmt:formatNumber value="${x.paidAmount}" minFractionDigits="2" maxFractionDigits="2"/></td><td>₹<fmt:formatNumber value="${x.balanceAmount}" minFractionDigits="2" maxFractionDigits="2"/></td></tr></c:forEach><c:if test="${empty summary}"><tr><td colspan="5">No billing data.</td></tr></c:if></tbody></table></div>
<h2 class="h4">Daily revenue trend</h2><p class="text-muted">Billed uses bill date. Paid/refunded use payment date; refunded payments are not counted as successful revenue.</p><table class="table"><thead><tr><th>Date</th><th>Billed</th><th>Successful payments</th><th>Refunded</th></tr></thead><tbody><c:forEach items="${trend}" var="x"><tr><td>${x.reportDate}</td><td>₹${x.billedAmount}</td><td>₹${x.paidAmount}</td><td>₹${x.refundedAmount}</td></tr></c:forEach><c:if test="${empty trend}"><tr><td colspan="4">No revenue data.</td></tr></c:if></tbody></table></main><c:if test="${printMode}"><script src="${pageContext.request.contextPath}/assets/js/reports-print.js" defer></script></c:if><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/footer.jsp" %></c:if></body></html>
