<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Admission and Bed Occupancy Report</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="${pageContext.request.contextPath}/assets/css/reports-print.css" rel="stylesheet"></head><body><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/header.jsp" %></c:if><main class="container py-4"><h1>Admission and Bed Occupancy Report</h1><p class="print-only">Online Hospital Management System</p><%@ include file="filter.jspf" %><c:if test="${empty printMode}"><p><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=admissions&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}&amp;doctorId=${filter.doctorId}">Export admissions</a> <a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=beds&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}">Export beds</a> <a class="btn btn-outline-secondary" href="?print=true&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}&amp;departmentId=${filter.departmentId}&amp;doctorId=${filter.doctorId}">Print view</a></p></c:if>
<h2 class="h4">Admission status</h2><table class="table table-striped"><thead><tr><th>Status</th><th>Admissions</th></tr></thead><tbody><c:forEach items="${admissionSummary}" var="x"><tr><td><c:out value="${x.status}"/></td><td>${x.admissionCount}</td></tr></c:forEach><c:if test="${empty admissionSummary}"><tr><td colspan="2">No admission data.</td></tr></c:if></tbody></table>
<h2 class="h4">Bed occupancy</h2><p class="text-muted">Operational beds exclude INACTIVE beds; maintenance beds remain visible in capacity.</p><table class="table"><thead><tr><th>Room type</th><th>Operational</th><th>Available</th><th>Occupied</th><th>Maintenance</th><th>Occupancy</th></tr></thead><tbody><c:forEach items="${bedSummary}" var="x"><tr><td><c:out value="${x.roomType}"/></td><td>${x.totalBeds}</td><td>${x.availableBeds}</td><td>${x.occupiedBeds}</td><td>${x.maintenanceBeds}</td><td>${x.occupancyPercentage}%</td></tr></c:forEach><c:if test="${empty bedSummary}"><tr><td colspan="6">No operational beds.</td></tr></c:if></tbody></table></main><c:if test="${printMode}"><script src="${pageContext.request.contextPath}/assets/js/reports-print.js" defer></script></c:if><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/footer.jsp" %></c:if></body></html>
