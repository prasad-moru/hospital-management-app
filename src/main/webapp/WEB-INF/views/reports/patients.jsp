<%@ page contentType="text/html;charset=UTF-8" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Patient Report</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="${pageContext.request.contextPath}/assets/css/reports-print.css" rel="stylesheet"></head><body><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/header.jsp" %></c:if><main class="container py-4"><h1>Patient Registration Report</h1><p class="print-only">Online Hospital Management System</p><%@ include file="filter.jspf" %><c:if test="${empty printMode}"><p><a class="btn btn-outline-success" href="${pageContext.request.contextPath}/admin/reports/export?type=patients&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}">Export CSV</a> <a class="btn btn-outline-secondary" href="?print=true&amp;dateFrom=${filter.dateFrom}&amp;dateTo=${filter.dateTo}">Print view</a></p></c:if><h2 class="h4">Registrations by status</h2><table class="table table-striped"><thead><tr><th>Status</th><th>Patients registered</th></tr></thead><tbody><c:forEach items="${statusSummary}" var="x"><tr><td><c:out value="${x.status}"/></td><td><c:out value="${x.patientCount}"/></td></tr></c:forEach><c:if test="${empty statusSummary}"><tr><td colspan="2">No patient data for this period.</td></tr></c:if></tbody></table><h2 class="h4">Daily registration trend</h2><table class="table table-striped"><thead><tr><th>Registration date</th><th>New patients</th></tr></thead><tbody><c:forEach items="${trend}" var="x"><tr><td><c:out value="${x.reportDate}"/></td><td><c:out value="${x.patientCount}"/></td></tr></c:forEach><c:if test="${empty trend}"><tr><td colspan="2" class="text-center">No registrations for this period.</td></tr></c:if></tbody></table></main><c:if test="${printMode}"><script src="${pageContext.request.contextPath}/assets/js/reports-print.js" defer></script></c:if><c:if test="${empty printMode}"><%@ include file="/WEB-INF/views/common/footer.jsp" %></c:if></body></html>
